# Prompt for GitHub CLI commands that mutate GitHub, alter local state, expose secrets, or launch interactive tools.
prefix_rule(pattern=["gh", "agent-task", "create"], decision="prompt")
prefix_rule(pattern=["gh", "alias", ["delete", "import", "set"]], decision="prompt")
prefix_rule(
    pattern = ["gh", "api"],
    decision = "forbidden",
    justification = "Use purpose-built gh subcommands, clone remote source into ~/workspaces/<repo-main-language-abbr>/<repo> for file inspection, or pause and suggest the exact gh api command for the user to run manually when raw API access is truly required.",
)
prefix_rule(pattern=["gh", "attestation", "download"], decision="prompt")
prefix_rule(pattern=["gh", "auth", ["logout", "refresh", "setup-git", "switch", "token"]], decision="prompt")
prefix_rule(pattern=["gh", "browse"], decision="prompt")
prefix_rule(pattern=["gh", "cache", "delete"], decision="prompt")
prefix_rule(pattern=["gh", "co"], decision="prompt")
prefix_rule(pattern=["gh", "codespace", ["code", "cp", "create", "delete", "edit", "jupyter", "ports", "rebuild", "ssh", "stop"]], decision="prompt")
prefix_rule(pattern=["gh", "config", ["clear-cache", "set"]], decision="prompt")
prefix_rule(pattern=["gh", "copilot"], decision="prompt")
prefix_rule(pattern=["gh", "extension", ["browse", "create", "exec", "install", "remove", "upgrade"]], decision="prompt")
prefix_rule(pattern=["gh", "gist", ["clone", "create", "delete", "edit", "rename"]], decision="prompt")
prefix_rule(pattern=["gh", "gpg-key", ["add", "delete"]], decision="prompt")
prefix_rule(pattern=["gh", "issue", ["close", "comment", "create", "delete", "develop", "edit", "lock", "pin", "reopen", "transfer", "unlock", "unpin"]], decision="prompt")
prefix_rule(pattern=["gh", "label", ["clone", "create", "delete", "edit"]], decision="prompt")
prefix_rule(pattern=["gh", "pr", ["checkout", "close", "comment", "create", "edit", "lock", "merge", "ready", "reopen", "revert", "review", "unlock", "update-branch"]], decision="prompt")
prefix_rule(pattern=["gh", "preview"], decision="prompt")
prefix_rule(pattern=["gh", "project", ["close", "copy", "create", "delete", "edit", "field-create", "field-delete", "item-add", "item-archive", "item-create", "item-delete", "item-edit", "link", "mark-template", "unlink"]], decision="prompt")
prefix_rule(pattern=["gh", "release", ["create", "delete", "delete-asset", "edit", "upload"]], decision="prompt")
prefix_rule(pattern=["gh", "repo", ["archive", "autolink", "create", "delete", "deploy-key", "edit", "fork", "rename", "set-default", "sync", "unarchive"]], decision="prompt")
prefix_rule(pattern=["gh", "run", ["cancel", "delete", "download", "rerun"]], decision="prompt")
prefix_rule(pattern=["gh", "secret", ["delete", "set"]], decision="prompt")
prefix_rule(pattern=["gh", "skill", ["install", "preview", "publish", "update"]], decision="prompt")
prefix_rule(pattern=["gh", "ssh-key", ["add", "delete"]], decision="prompt")
prefix_rule(pattern=["gh", "variable", ["delete", "set"]], decision="prompt")
prefix_rule(pattern=["gh", "workflow", ["disable", "enable", "run"]], decision="prompt")

# Allow read-only Windows package-manager inspection commands.
prefix_rule(pattern=["winget", ["list", "search", "show"]], decision="allow")
prefix_rule(pattern=["winget", "source", "list"], decision="allow")
prefix_rule(pattern=["scoop", ["list", "status", "info", "search", "prefix", "which"]], decision="allow")

prefix_rule(pattern=["ssh"], decision="prompt")
prefix_rule(pattern=["scp"], decision="prompt")
