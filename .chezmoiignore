{{- $machineForm := get . "machineForm" -}}
{{- if and $machineForm (ne $machineForm "headless") (ne $machineForm "headed") -}}{{ fail "machineForm must be headless or headed" }}{{- end -}}
{{- $isWSL := and (eq .chezmoi.os "linux") (.chezmoi.kernel.osrelease | lower | contains "microsoft") -}}
{{- $isBareMetal := not $isWSL -}}
{{- $isHeaded := $isBareMetal -}}
{{- if eq $machineForm "headless" -}}{{- $isHeaded = false -}}{{- end -}}
{{- if eq $machineForm "headed" -}}{{- $isHeaded = true -}}{{- end -}}
{{- $isHeadless := not $isHeaded -}}
{{- $manageEtcMirror := get . "manageEtcMirror" | default false -}}
AGENTS.md
HANDOFF.*.md
README.md
scripts
scripts/**

{{- if $isHeadless }}
.config/fontconfig/**
.config/fcitx5/**
.config/fish/functions/setfps.fish
.config/mpv/**
.config/pipewire/**
.config/sunshine/**
.local/share/gnome-background-properties/**
.local/share/qBittorrent/**
.mozilla/**
{{- end }}

{{- if $isWSL }}
.config/aria2/**
.config/libvirt/**
.config/systemd/user/aria2cd.service
.config/ventoy/**
.config/yt-dlp/**
{{- end }}

# /etc mirror is opt-in for templating and review.
{{- if not $manageEtcMirror }}
etc/**
{{- else }}
etc/powerpill/**
{{- if $isHeadless }}
etc/environment
etc/interception/**
etc/systemd/system/bluetooth.service.d/**
etc/systemd/system/gdm.service.d/**
{{- end }}

{{- if $isWSL }}
etc/cmdline.d/**
etc/inadyn.conf
etc/mkinitcpio.conf.d/**
etc/samba/**
etc/ssh/sshd_config.d/**
etc/sysctl.d/**
etc/systemd/logind.conf.d/**
etc/systemd/system.conf.d/**
etc/systemd/zram-generator.conf
etc/xray/**
{{- end }}
{{- end }}
