# Never let Codex send mail.
prefix_rule(
    pattern = ["gws", "gmail", ["+send", "+reply", "+reply-all", "+forward"]],
    decision = "forbidden",
    justification = "Do not send mail automatically. Create or update a draft instead.",
)

prefix_rule(
    pattern = ["gws", "gmail", "users", "messages", "send"],
    decision = "forbidden",
    justification = "Do not send mail automatically. Create or update a draft instead.",
)

prefix_rule(
    pattern = ["gws", "gmail", "users", "drafts", "send"],
    decision = "forbidden",
    justification = "Drafts may be created, but never sent by Codex.",
)

# Prefer pnpm for Node package manager and CLI execution.
prefix_rule(
    pattern = [["npm", "npx", "pnpx", "yarn", "yarnpkg", "bun", "bunx"]],
    decision = "forbidden",
    justification = "Use pnpm instead: pnpm run <script>, pnpm exec <tool>, pnpm dlx <pkg>, or the matching pnpm install/add/remove/update command.",
)

# Prefer the globally installed Context7 CLI instead of one-shot runners.
prefix_rule(
    pattern = ["pnpm", "dlx", ["ctx7", "ctx7@latest"]],
    decision = "forbidden",
    justification = "Use the globally installed ctx7 on PATH instead of pnpm dlx ctx7.",
)

# Allow running tests based on CloudFlare workers.
prefix_rule(
    pattern = ["pnpm", "run", "test:workers"],
    decision = "allow",
)

# Allow some easily reversible Git mutative operations.
prefix_rule(pattern=["git", ["add", "apply", "branch", "checkout", "cherry-pick", "commit", "fetch", "merge", "mv", "rebase", "restore", "rm", "switch"]], decision="allow")
prefix_rule(pattern=["git", "-c", "core.editor=true", ["cherry-pick", "rebase"]], decision="allow")
prefix_rule(pattern=["git", "stash", ["branch", "create", "export", "list", "push", "show", "store"]], decision="allow")

# Prompt before mutating remote Git refs.
prefix_rule(pattern=["git", "lfs", "push"], decision="prompt")
prefix_rule(pattern=["git", "push"], decision="prompt")

