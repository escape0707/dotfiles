{{ $machineForm := get . "machineForm" -}}
{{ if and $machineForm (ne $machineForm "headless") (ne $machineForm "headed") -}}{{ fail "machineForm must be headless or headed" }}{{ end -}}
--concurrent-fragments 32
{{ if eq $machineForm "headless" -}}
--cookies ~/.config/yt-dlp/cookies.txt
{{ else -}}
--cookies-from-browser firefox
{{ end -}}
#--downloader aria2c
--embed-metadata
--embed-subs
--embed-thumbnail
# Avoid av1 for video resolution above 2K
#--format bestvideo*[height=2160][vcodec!=av01]+bestaudio/bestvideo*[height>1440][vcodec!=av01]+bestaudio/bestvideo*[height<=1440]+bestaudio/bestvideo*+bestaudio/best
# Prefer av1
--format-sort quality,res,fps,hdr:12,source,vcodec
--keep-video
--mark-watched
--output "%(playlist)s/%(playlist_index)s_%(title)s.%(ext)s"
--paths "~/Videos/web-dl"
--sub-langs en.*,zh.*,ja.*,live_chat
--write-auto-sub
--write-sub
