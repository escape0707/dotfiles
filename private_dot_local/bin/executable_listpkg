#!/usr/bin/env bash
set -euo pipefail

configured_groups=('gnome' 'fcitx5-im')

group_packages() {
    pacman -Qqg "${configured_groups[@]}" 2>/dev/null | sort --unique
}

group_atoms() {
    for group in "${configured_groups[@]}"; do
        pacman -Qqg "$group" 2>/dev/null | sed -n "1s/.*/$group/p"
    done | sort --unique
}

roots() {
    comm -23 \
        <(pacman -Qqtt | sort --unique) \
        <(group_packages)
}

installed_pins() {
    comm -12 \
        <(sort --unique "$HOME/pkg-pin-if-present.txt") \
        <(pacman -Qq | sort --unique)
}

sort --unique <(roots) <(group_atoms) <(installed_pins)
