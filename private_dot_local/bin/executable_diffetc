#!/usr/bin/env bash
set -euo pipefail

runtime_dir=${XDG_RUNTIME_DIR:-"/run/user/$(id --user)"}

# for each managed /etc file:
#     if chezmoi status for that file is empty:
#         skip it
#     if live file is missing:
#         offer cat/apply/delete/skip/quit until resolved
#     otherwise:
#         offer mergetool/skip/quit
chezmoi_args=(
    --override-data '{"manageEtcMirror":true}'
    --destination /
)

while IFS= read -r -d '' -u 3 managed; do
    live="/$managed"
    status=$(chezmoi "${chezmoi_args[@]}" status --include files "$live")
    [[ -n "$status" ]] || continue

    source=$(chezmoi "${chezmoi_args[@]}" source-path "$live")

    if [[ ! -e "$live" ]]; then
        while [[ ! -e "$live" ]]; do
            printf '%s is missing\n' "$live"
            read -r -p 'Cat rendered, apply rendered, delete source, skip, or quit? [c/a/d/S/q] ' reply

            case "$reply" in
                [Dd]*) rm -- "$source"; break ;;
                [Qq]*) exit 0 ;;
                [Cc]*)
                    chezmoi "${chezmoi_args[@]}" cat "$live"
                    ;;
                [Aa]*)
                    rendered=$(mktemp "$runtime_dir/diffetc.XXXXXXXXXX")
                    trap 'rm --force -- "$rendered"' EXIT

                    chezmoi "${chezmoi_args[@]}" cat "$live" >"$rendered"

                    sudo install -D --mode=0644 "$rendered" "$live"
                    rm -- "$rendered"
                    trap - EXIT
                    ;;
                *) break ;;
            esac
        done

        continue
    fi

    printf '%s\n' "$live"
    read -r -p 'Open mergetool with rendered/source/live? [y/N/q] ' reply

    case "$reply" in
        [Qq]*) exit 0 ;;
        [Yy]*)
            rendered=$(mktemp "$runtime_dir/diffetc.XXXXXXXXXX")
            trap 'rm --force -- "$rendered"' EXIT

            chezmoi "${chezmoi_args[@]}" cat "$live" >"$rendered"

            SUDO_EDITOR="nvim -d $rendered $source" sudoedit "$live" || true
            rm -- "$rendered"
            trap - EXIT
            ;;
    esac
done 3< <(chezmoi "${chezmoi_args[@]}" managed --include files --nul-path-separator /etc)
